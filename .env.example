# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
# Model used only for query rewriting (fast, cheap — Haiku is enough)
REWRITE_MODEL=claude-haiku-4-5-20251001

# ── Embeddings ─────────────────────────────────────────────
# Options: local | openai
EMBEDDING_PROVIDER=local

# Required only when EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# ── Retrieval ──────────────────────────────────────────────
TOP_K=5

# ── Storage ────────────────────────────────────────────────
# Inside the container; mapped to ./backend/chroma_store on the host
CHROMA_DIR=/app/chroma_store
